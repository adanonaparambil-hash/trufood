# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git — it is already in .gitignore.

# Gmail SMTP (use an App Password, NOT your regular Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# The inbox that receives contact form submissions
CONTACT_TO_EMAIL=info@trufudoman.com
